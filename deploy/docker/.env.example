PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
REGISTRY_PORT=5000

# Use ./prometheus/file_sd/local for one-server tests.
# Use ./prometheus/file_sd/remote when Prometheus scrapes exporters on other servers.
PROMETHEUS_FILE_SD_DIR=./prometheus/file_sd/remote

NODE_EXPORTER_PORT=9100
DCGM_EXPORTER_PORT=9400
PCM_EXPORTER_PORT=9738

# Override these for internal mirrors or custom builds.
PROMETHEUS_IMAGE=prom/prometheus:latest
GRAFANA_IMAGE=grafana/grafana:latest
REGISTRY_IMAGE=registry:2
NODE_EXPORTER_IMAGE=prom/node-exporter:latest
DCGM_EXPORTER_IMAGE=nvcr.io/nvidia/k8s/dcgm-exporter:latest
PCM_EXPORTER_IMAGE=ghcr.io/intel/pcm:latest
PCM_PLATFORM=linux/amd64
PCM_IGNORE_ARCH_PERFMON=0
PCM_NO_PERF=0

# Exporter profiles to start on this server.
# Examples:
#   node only:        COMPOSE_PROFILES=node
#   node + GPU:      COMPOSE_PROFILES=node,gpu
#   node + PCM/CXL:  COMPOSE_PROFILES=node,pcm
#   all exporters:   COMPOSE_PROFILES=node,gpu,pcm
COMPOSE_PROFILES=node
